{
    "name": "brand-snapshot",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "next dev -p 3010",
        "dev:preview": "next dev -p 3010",
        "dev:preview:restart": "bash scripts/dev-preview-restart.sh",
        "dev:preview:watch": "bash scripts/dev-preview-watch.sh",
        "build": "next build --webpack",
        "start": "next start",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "lint": "eslint . --ext .ts,.tsx",
        "types:supabase": "npx supabase gen types typescript --project-id wunderbar-digital-prod > supabase/types.ts",
        "scan": "npx tsx scripts/health-check.ts",
        "scan:fix": "npx tsx scripts/health-check.ts --fix",
        "scan:full": "npx tsx scripts/health-check.ts --build",
        "guard:webhook-public-env": "npx tsx scripts/guard-public-webhooks.ts",
        "qa:wundy-voice": "npx tsx scripts/qa-wundy-voice.ts",
        "qa:wundy-voice:golden": "npx tsx scripts/qa-wundy-voice.ts --responses scripts/wundy-voice-responses.golden.json",
        "check:pdf-parity": "npx tsx scripts/check-pdf-parity.ts",
        "verify:preview-samples": "npx tsx scripts/verify-preview-samples.ts",
        "resume:dev": "bash scripts/resume-dev.sh",
        "resume:dev:full": "bash scripts/resume-dev.sh --full",
        "resume:snapshot": "bash scripts/resume-snapshot.sh",
        "dev:restart": "bash scripts/dev-restart.sh",
        "stress:dev": "npx --yes autocannon -c 20 -d 15 -p 10 http://localhost:3010/api/health && npx --yes autocannon -c 20 -d 15 -p 10 \"http://localhost:3010/api/health?scope=liveness\" && npx --yes autocannon -c 20 -d 15 -p 10 http://localhost:3010/access",
        "stress:prod": "npx --yes autocannon -c 20 -d 15 -p 10 http://localhost:3030/api/health && npx --yes autocannon -c 20 -d 15 -p 10 \"http://localhost:3030/api/health?scope=liveness\" && npx --yes autocannon -c 20 -d 15 -p 10 http://localhost:3030/access",
        "stress:liveness": "npx --yes autocannon -c 20 -d 30 -p 10 \"http://localhost:3030/api/health?scope=liveness\"",
        "stress:compare": "npx tsx scripts/stress-report.ts",
        "stress:compare:quick": "npx tsx scripts/stress-report.ts --duration 5 --connections 10 --pipelining 5",
        "stress:compare:ci": "npx tsx scripts/stress-report.ts --duration 5 --connections 10 --pipelining 5 --fail-on-threshold --threshold-target prod",
        "stress:compare:ci:strict": "npx tsx scripts/stress-report.ts --duration 5 --connections 10 --pipelining 5 --fail-on-threshold --threshold-target prod --profile strict",
        "lint:fix": "eslint . --ext .ts,.tsx --fix",
        "typecheck": "tsc --noEmit --pretty",
        "audit": "npm audit --production",
        "audit:fix": "npm audit fix --production",
        "health": "curl -s http://localhost:3010/api/health | node -e \"process.stdin.on('data',d=>{const h=JSON.parse(d);console.log(h.status==='healthy'?'✅ Healthy':'⚠️ '+h.status);Object.entries(h.checks).forEach(([k,v])=>console.log('  '+k+': '+(v.ok?'✅':'❌ '+v.error)))})\"",
        "preflight": "bash scripts/preflight-prod.sh",
        "setup:ac": "npx tsx scripts/setup-activecampaign.ts"
    },
    "overrides": {
        "postcss": "^8.5.10"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.78.0",
        "@fontsource/inter": "^5.2.8",
        "@fontsource/lato": "^5.2.7",
        "@fontsource/merriweather": "^5.2.11",
        "@google/generative-ai": "^0.24.1",
        "@react-pdf/renderer": "^4.3.1",
        "@sentry/nextjs": "^10.52.0",
        "@tailwindcss/postcss": "^4.2.0",
        "@types/uuid": "^10.0.0",
        "@vercel/og": "^0.8.5",
        "disposable-email-domains": "^1.0.62",
        "jszip": "^3.10.1",
        "next": "^16.2.6",
        "openai": "^6.22.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sharp": "^0.34.5",
        "stripe": "^17.0.0",
        "uuid": "^13.0.0",
        "write-excel-file": "^4.0.6",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@next/bundle-analyzer": "^16.2.6",
        "@playwright/test": "^1.60.0",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.97.0",
        "@types/node": "^20",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/ui": "^4.0.18",
        "autoprefixer": "^10.4.22",
        "eslint": "^9.39.2",
        "eslint-config-next": "^16.2.6",
        "postcss": "^8.5.10",
        "supabase": "^2.76.12",
        "tailwindcss": "^4.2.0",
        "typescript": "^5.5.3",
        "vitest": "^4.0.18"
    }
}
